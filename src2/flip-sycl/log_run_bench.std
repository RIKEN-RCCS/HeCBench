clang++  -std=c++17 -Wall -fsycl  -I../flip-cuda           --gcc-toolchain= -fsycl-targets=nvptx64-nvidia-cuda             -Xsycl-target-backend --cuda-gpu-arch=sm_90  -fno-sycl-id-queries-fit-in-int -O3 -DUSE_GPU -c main.cpp -o main.o
clang++  -std=c++17 -Wall -fsycl  -I../flip-cuda           --gcc-toolchain= -fsycl-targets=nvptx64-nvidia-cuda             -Xsycl-target-backend --cuda-gpu-arch=sm_90  -fno-sycl-id-queries-fit-in-int -O3 -DUSE_GPU main.o -o main 
nvidia-smi --query-gpu=memory.used,memory.total --format=csv --loop-ms=1 > log.mem &
bash -c "time -p ( ./main 3 1200 100 1>log.std 2>log.err ) 2> log.time"
pkill nvidia-smi
